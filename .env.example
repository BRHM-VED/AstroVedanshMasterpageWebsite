# API Base URL for backend requests
# In local development, set this to your local backend server URL or proxy path '/api'.
# In production, set this to the full URL of your deployed Laravel API.
VITE_API_BASE=https://phpbackend.astrovedansh.org/api

# Proxy target for local development server (Vite proxy config)
# Change this if your local Laravel server runs on a different port or host.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Vedic-calculation engine base URL, used by the CMS backend proxy — kept
# here for reference only, the frontend never talks to this host directly.
ASTROTRY_BASE_URL=https://ciirag-astrotry.hf.space

# Optional — analytics & error tracking. Leave both unset and nothing loads
# (no script tags, no network calls). Set after creating your own account:
#   VITE_PLAUSIBLE_DOMAIN=astrovedansh.org        (https://plausible.io)
#   VITE_SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0   (https://sentry.io)
